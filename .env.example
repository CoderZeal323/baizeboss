# BaizeBoss reads its Supabase connection details from public/js/config.js,
# not from a .env file — this is a static site with no build step.
#
# This file is just a reference for what to put in config.js.
# (Project Settings > API in your Supabase dashboard.)

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Never put your "service_role" key in this project. It bypasses Row
# Level Security entirely and must never reach a browser.
